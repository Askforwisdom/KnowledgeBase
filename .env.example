# 环境配置文件示例
# 复制此文件为 .env 并修改配置

# 项目配置
PROJECT_NAME=Knowledge Base System
DEBUG=false

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/knowledge.db
DATABASE_POOL_SIZE=5

# 嵌入模型配置
ENABLE_EMBEDDING=true
EMBEDDING_MODEL=qwen3
EMBEDDING_DIMENSION=1024
SIMILARITY_THRESHOLD=0.7

# 嵌入批处理配置
EMBEDDING_BATCH_SIZE=256
EMBEDDING_MAX_MEMORY_GB=4.0

# 导入配置
IMPORT_MAX_WORKERS=4
IMPORT_BATCH_SIZE=256
IMPORT_CHUNK_BATCH_SIZE=512

# 分块配置
CHUNK_MAX_SIZE=1000
CHUNK_MIN_SIZE=100
CHUNK_OVERLAP_SIZE=100
CHUNK_MAX_PER_KNOWLEDGE=50
CHUNK_ENABLE_AI_SEMANTIC=true

# API服务配置
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# 文件处理配置
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS_STR=.docx,.doc,.txt,.md,.json,.yaml,.yml,.groovy

# 外部嵌入模型配置（可选）
EXTERNAL_EMBEDDING_ENABLED=false
EXTERNAL_EMBEDDING_API_URL=
EXTERNAL_EMBEDDING_API_KEY=
EXTERNAL_EMBEDDING_MODEL=text-embedding-ada-002
EXTERNAL_EMBEDDING_DIMENSION=1536
EXTERNAL_EMBEDDING_TIMEOUT=30
